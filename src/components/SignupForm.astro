---
---

<section class="signup-section">
  <div class="signup-inner">
    <h2 class="signup-headline">Join Team<br />Barrie<span class="accent-dot">.</span></h2>
    <div class="signup-form-card">

      <form class="signup-form" method="POST" action="#signup">
        <div class="sf-row">
          <div class="sf-field">
            <label for="sf-fname">First Name</label>
            <input type="text" id="sf-fname" name="first_name" required />
          </div>
          <div class="sf-field">
            <label for="sf-lname">Last Name</label>
            <input type="text" id="sf-lname" name="last_name" required />
          </div>
        </div>
        <div class="sf-row">
          <div class="sf-field">
            <label for="sf-email">Email Address</label>
            <input type="email" id="sf-email" name="email" required />
          </div>
          <div class="sf-field">
            <label for="sf-zip">Zip Code</label>
            <input type="text" id="sf-zip" name="zip" inputmode="numeric" pattern="[0-9]{5}" required />
          </div>
        </div>
        <button type="submit" class="signup-submit">Get Updates</button>
      </form>
    </div>
    <div class="signup-photo">
      <img src="/images/Campaign Kickoff 033026.jpg" alt="Campaign Kickoff" class="signup-photo-img" />
    </div>
  </div>
</section>

<style>
  .signup-section {
    position: relative;
    background: var(--cream-dark);
    padding: 5rem 2rem;
    overflow: hidden;
    border-top: 3px solid var(--gold);
  }

  .accent-dot { color: var(--teal); }

  .signup-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.5fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .signup-photo { align-self: start; }

  .signup-photo-img {
    width: 100%;
    height: auto;
    border-radius: var(--border-radius);
    box-shadow: var(--shadow-md);
    display: block;
  }

  .signup-headline {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 6vw, 4.5rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--teal);
  }

  .signup-form-card {
    background: var(--white);
    border: 1px solid var(--light-gray);
    border-radius: var(--border-radius);
    padding: 2rem;
    box-shadow: var(--shadow-sm);
  }

  .sf-row { display: flex; gap: 0.75rem; margin-bottom: 0.75rem; }
  .sf-field { flex: 1; display: flex; flex-direction: column; }

  .sf-field label {
    font-family: var(--font-primary);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--dark-gray);
    margin-bottom: 0.3rem;
  }

  .sf-field input {
    padding: 0.7rem 0.65rem;
    font-size: 1rem;
    font-family: var(--font-primary);
    background: var(--bg);
    border: 2px solid var(--light-gray);
    border-radius: 4px;
    color: var(--text);
    outline: none;
    transition: border-color 0.2s;
  }

  .sf-field input:focus { border-color: var(--teal); }

  .signup-submit {
    width: 100%;
    padding: 0.9rem;
    font-family: var(--font-primary);
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: var(--primary);
    color: var(--white);
    border: none;
    border-radius: 4px;
    cursor: pointer;
    transition: background 0.2s;
    margin-top: 0.25rem;
  }

  .signup-submit:hover { background: var(--primary-light); }

  @media (max-width: 900px) {
    .signup-inner { grid-template-columns: 1fr; gap: 2rem; }
    .sf-row { flex-direction: column; gap: 0.5rem; }
  }
</style>
