---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SignupForm from '../components/SignupForm.astro';
import { donateUrl, socialLinks } from '../data/navigation';
---

<BaseLayout title="Fatmata Barrie for Montgomery County Council At-Large" description="Let's Move Montgomery County Forward — Together. Immigration attorney, small business owner, community leader.">
  <Header />
  <main>

    <!-- HERO -->
    <section class="hero">
      <div class="container hero-inner">
        <div class="hero-text">
          <span class="ornament" style="margin: 0 0 1.5rem;"></span>
          <h1 class="hero-headline">Let's Move<br />Montgomery County<br /><em>Forward — Together.</em></h1>
          <p class="hero-sub">Immigration attorney. Small business owner. Community leader. Fatmata Barrie is running for Council At-Large to deliver for every resident of Montgomery County.</p>
          <div class="hero-ctas">
            <a href={donateUrl} class="btn btn-accent">Donate Now</a>
            <a href="/platform" class="btn btn-outline-light">See the Platform</a>
          </div>
        </div>
        <div class="hero-portrait">
          <img src="/images/fatmata-about.png" alt="Fatmata Barrie speaking" class="hero-portrait-img" />
        </div>
      </div>
    </section>

    <!-- INTRO QUOTE -->
    <section class="section intro-quote">
      <div class="container text-center">
        <span class="ornament"></span>
        <blockquote>
          "I know what it means to face uncertainty and still show up for everyone everyday. We need an experienced fighter who will push forward an agenda for a more inclusive community for all."
        </blockquote>
        <cite>&mdash; Fatmata Barrie</cite>
      </div>
    </section>

    <!-- ISSUES PREVIEW -->
    <section class="section section-alt issues">
      <div class="container">
        <div class="text-center" style="margin-bottom: 3rem;">
          <p class="section-label">The Platform</p>
          <h2>Six priorities for Montgomery County.</h2>
          <span class="ornament"></span>
        </div>

        <div class="issues-grid">
          <a href="/platform#democracy" class="issue-card issue-featured">
            <div class="issue-number">01</div>
            <h3>Defending Democracy</h3>
            <p>Protect civil liberties. No ICE collaboration. Defend our inclusive community against federal overreach.</p>
          </a>
          <a href="/platform#education" class="issue-card">
            <div class="issue-number">02</div>
            <h3>Education</h3>
            <p>Shield schools from cuts. Support educators. Champion community schools.</p>
          </a>
          <a href="/platform#affordability" class="issue-card">
            <div class="issue-number">03</div>
            <h3>Affordability</h3>
            <p>Affordable housing. Eliminate food deserts. Protect seniors on fixed incomes.</p>
          </a>
          <a href="/platform#business" class="issue-card">
            <div class="issue-number">04</div>
            <h3>Business &amp; Economy</h3>
            <p>Incentives for small businesses. Local hiring. Minority business access.</p>
          </a>
          <a href="/platform#transportation" class="issue-card">
            <div class="issue-number">05</div>
            <h3>Transportation</h3>
            <p>WMATA access. Complete the Purple Line. Expand RideOn and bike safety.</p>
          </a>
          <a href="/platform#health" class="issue-card">
            <div class="issue-number">06</div>
            <h3>Health</h3>
            <p>Expand clinics. Youth mental health. Maternal health equity.</p>
          </a>
        </div>
      </div>
    </section>

    <!-- MEET FATMATA -->
    <section class="section meet">
      <div class="container meet-inner">
        <div class="meet-portrait">
          <img src="/images/fatmata-about.png" alt="Fatmata Barrie speaking" class="meet-portrait-img" />
        </div>
        <div class="meet-text">
          <p class="section-label">Meet Fatmata</p>
          <h2>An experienced fighter.<br />A community leader.</h2>
          <span class="ornament" style="margin: 1rem 0;"></span>
          <p>Fatmata Barrie immigrated from Sierra Leone at age 11 and has called Montgomery County home for over 22 years. As an immigration and special education attorney, she has spent more than two decades fighting for the most vulnerable members of our community.</p>
          <p>She served as Executive Director of the Montgomery County Police Accountability Board, worked with Councilmember Will Jawando, and founded "Africans in the Diaspora for Harris" — a coalition of over 2,000 members.</p>
          <a href="/about" class="btn btn-outline">Read Full Bio</a>
        </div>
      </div>
    </section>

    <!-- PUBLIC FINANCING -->
    <section class="section section-alt financing">
      <div class="container text-center">
        <p class="section-label">People-Powered Campaign</p>
        <h2>Your donation is matched.</h2>
        <span class="ornament"></span>
        <p style="max-width: 600px; margin: 1rem auto 2rem; color: var(--text-light);">Fatmata is participating in Montgomery County's public financing program. No corporate money. No PACs. Only small-dollar donations — and they're matched.</p>
        <div class="match-grid">
          <div class="match-card">
            <span class="match-give">$25</span>
            <span class="match-arrow">&rarr;</span>
            <span class="match-get">$150</span>
          </div>
          <div class="match-card">
            <span class="match-give">$50</span>
            <span class="match-arrow">&rarr;</span>
            <span class="match-get">$300</span>
          </div>
          <div class="match-card">
            <span class="match-give">$150</span>
            <span class="match-arrow">&rarr;</span>
            <span class="match-get">$650</span>
          </div>
          <div class="match-card match-card-featured">
            <span class="match-give">$250</span>
            <span class="match-arrow">&rarr;</span>
            <span class="match-get">$750</span>
          </div>
        </div>
        <a href={donateUrl} class="btn btn-accent" style="margin-top: 2rem;">Donate Now</a>
      </div>
    </section>

    <!-- GET INVOLVED -->
    <section class="section involve">
      <div class="container">
        <div class="text-center" style="margin-bottom: 2.5rem;">
          <p class="section-label">Get Involved</p>
          <h2>Join the campaign.</h2>
          <span class="ornament"></span>
        </div>
        <div class="involve-cards">
          <a href="/volunteer" class="involve-card">
            <h3>Volunteer</h3>
            <p>Join the team and help power a people-first campaign.</p>
            <span class="involve-link">Sign up &rsaquo;</span>
          </a>
          <a href="/contact" class="involve-card">
            <h3>Contact Us</h3>
            <p>Questions? Ideas? We want to hear from you.</p>
            <span class="involve-link">Get in touch &rsaquo;</span>
          </a>
          <a href={donateUrl} class="involve-card involve-card-accent">
            <h3>Donate</h3>
            <p>$500 max. No corporate money. Your gift is matched!</p>
            <span class="involve-link">Contribute &rsaquo;</span>
          </a>
        </div>
      </div>
    </section>

    <!-- CTA BANNER -->
    <section class="cta-banner">
      <div class="container text-center">
        <h2>Election Day is June 23.</h2>
        <p>Let's move Montgomery County forward — together.</p>
        <div class="cta-buttons">
          <a href={donateUrl} class="btn btn-accent">Donate</a>
          <a href="/volunteer" class="btn btn-outline-light">Volunteer</a>
        </div>
      </div>
    </section>

    <SignupForm />

  </main>
  <Footer />
</BaseLayout>

<style>
  /* HERO */
  .hero {
    position: relative;
    min-height: 85vh;
    display: flex;
    align-items: center;
    background: var(--primary);
    overflow: hidden;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 3rem;
    align-items: center;
    padding: 4rem 1.5rem;
  }

  .hero-headline {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 7vw, 5rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--white);
    margin-bottom: 1.5rem;
  }

  .hero-headline em {
    color: var(--teal);
    font-style: italic;
  }

  .hero-sub {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: rgba(255,255,255,0.7);
    max-width: 500px;
    margin-bottom: 2.5rem;
    line-height: 1.7;
  }

  .hero-ctas { display: flex; gap: 1rem; flex-wrap: wrap; }

  .hero-portrait { display: flex; justify-content: center; align-items: center; }

  .hero-portrait-img {
    max-width: 100%;
    width: 420px;
    height: auto;
    border-radius: 8px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    object-fit: cover;
    height: 400px;
  }

  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; text-align: center; }
    .hero-portrait { order: -1; }
    .hero-portrait-img { width: 280px; }
    .hero-sub { margin-left: auto; margin-right: auto; }
    .hero-ctas { justify-content: center; }
  }

  /* INTRO QUOTE */
  .intro-quote { background: var(--bg); padding: 4rem 1.5rem; }

  .intro-quote blockquote {
    font-family: var(--font-heading);
    font-size: clamp(1.15rem, 2.5vw, 1.5rem);
    font-weight: 400;
    font-style: italic;
    line-height: 1.7;
    color: var(--text);
    max-width: 750px;
    margin: 1rem auto;
  }

  .intro-quote cite {
    display: block;
    font-family: var(--font-primary);
    font-style: normal;
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--primary);
    margin-top: 1rem;
    letter-spacing: 0.05em;
  }

  /* ISSUES */
  .issues-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .issue-card {
    background: var(--white);
    border: 1px solid var(--light-gray);
    border-radius: var(--border-radius);
    padding: 2rem;
    transition: border-color 0.3s, transform 0.2s, box-shadow 0.3s;
    text-decoration: none;
    color: var(--text);
    display: block;
  }

  .issue-card:hover {
    border-color: var(--primary);
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    color: var(--text);
  }

  .issue-featured {
    border-left: 4px solid var(--accent);
  }

  .issue-number {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--gold);
    margin-bottom: 0.5rem;
  }

  .issue-card h3 { font-size: 1.2rem; margin-bottom: 0.5rem; color: var(--primary); }
  .issue-card p { color: var(--text-light); font-size: 0.95rem; line-height: 1.6; }

  @media (max-width: 768px) {
    .issues-grid { grid-template-columns: 1fr; }
  }

  /* MEET */
  .meet-inner {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 4rem;
    align-items: center;
  }

  .meet-portrait-img {
    width: 100%;
    max-width: 340px;
    height: auto;
    border-radius: 8px;
    border: 3px solid var(--teal);
    box-shadow: var(--shadow-md);
    object-fit: cover;
    margin: 0 auto;
    display: block;
  }

  .meet-text h2 { margin-bottom: 0; }
  .meet-text p { color: var(--text-light); font-size: 1.05rem; line-height: 1.7; margin-bottom: 1rem; }

  @media (max-width: 768px) {
    .meet-inner { grid-template-columns: 1fr; gap: 2rem; }
    .meet-portrait { order: -1; }
  }

  /* FINANCING */
  .match-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    max-width: 700px;
    margin: 0 auto;
  }

  .match-card {
    background: var(--white);
    border: 1px solid var(--light-gray);
    border-radius: var(--border-radius);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    box-shadow: var(--shadow-sm);
  }

  .match-card-featured { border-color: var(--teal); border-width: 2px; }
  .match-give { font-family: var(--font-heading); font-size: 1rem; color: var(--text-light); }
  .match-arrow { color: var(--gold); font-size: 1.25rem; }
  .match-get { font-family: var(--font-heading); font-size: 1.5rem; font-weight: 700; color: var(--teal); }

  @media (max-width: 640px) {
    .match-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* INVOLVE */
  .involve-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .involve-card {
    display: flex;
    flex-direction: column;
    padding: 2rem;
    background: var(--white);
    border: 1px solid var(--light-gray);
    border-radius: var(--border-radius);
    text-decoration: none;
    color: var(--text);
    transition: all 0.25s;
    box-shadow: var(--shadow-sm);
  }

  .involve-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); border-color: var(--primary); color: var(--text); }

  .involve-card-accent { background: var(--accent); border-color: var(--accent); color: var(--white); }
  .involve-card-accent:hover { background: var(--accent-bright); border-color: var(--accent-bright); color: var(--white); }
  .involve-card-accent h3 { color: var(--white); }
  .involve-card-accent p { color: rgba(255,255,255,0.85); }
  .involve-card-accent .involve-link { color: var(--white); }

  .involve-card h3 { font-size: 1.2rem; margin-bottom: 0.5rem; color: var(--teal); }
  .involve-card p { font-size: 0.95rem; line-height: 1.6; color: var(--text-light); flex: 1; }

  .involve-link {
    font-family: var(--font-primary);
    font-weight: 700;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--primary);
    margin-top: 1rem;
  }

  @media (max-width: 768px) { .involve-cards { grid-template-columns: 1fr; } }

  /* CTA BANNER */
  .cta-banner {
    background: var(--primary);
    padding: 4rem 2rem;
  }

  .cta-banner h2 { font-size: clamp(1.8rem, 4vw, 3rem); margin-bottom: 0.5rem; color: var(--white); }
  .cta-banner p { color: rgba(255,255,255,0.7); font-size: 1.1rem; margin-bottom: 2rem; font-family: var(--font-primary); }
  .cta-buttons { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
</style>
