---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SignupForm from '../components/SignupForm.astro';
import { donateUrl, socialLinks } from '../data/navigation';
---

<BaseLayout title="Fatmata Barrie for Montgomery County Council At-Large" description="I'm running for Council to deliver for the people of Montgomery County. Immigration and special education attorney, community activist for 30+ years.">
  <Header />

  <!-- DONATION POPUP -->
  <div id="donation-popup" class="popup-overlay" aria-hidden="true">
    <div class="popup-modal" role="dialog" aria-labelledby="popup-title">
      <button class="popup-close" id="popup-close-btn" aria-label="Close">&times;</button>
      <h2 id="popup-title" class="popup-headline">This campaign is fueled by everyday people.</h2>
      <p class="popup-text">As a public finance candidate, I'm not taking corporate PAC money or donations over $500. I need your help reaching my goal. Can you contribute:</p>
      <div class="donation-grid">
        <a href={`${donateUrl}?amount=5`} class="donation-btn">$5</a>
        <a href={`${donateUrl}?amount=10`} class="donation-btn">$10</a>
        <a href={`${donateUrl}?amount=25`} class="donation-btn">$25</a>
        <a href={`${donateUrl}?amount=50`} class="donation-btn">$50</a>
        <a href={`${donateUrl}?amount=100`} class="donation-btn">$100</a>
        <a href={`${donateUrl}?amount=250`} class="donation-btn">$250</a>
        <a href={donateUrl} class="donation-btn donation-other">Other</a>
      </div>
    </div>
  </div>

  <main>

    <!-- HERO -->
    <section class="hero">
      <div class="container hero-inner">
        <div class="hero-portrait">
          <img src="/images/CampaignHeadshot32426-1.png" alt="Fatmata Barrie" class="hero-portrait-img" />
        </div>
        <div class="hero-text">
          <blockquote class="hero-quote">
            "I'm running for Council to deliver for the people of Montgomery County. As an immigration and special education attorney and community activist for more than 30 years, I know what it means to face uncertainty and still show up for everyone everyday. We need an experienced fighter who will push forward an agenda for a more inclusive community for all and protect the future of Montgomery County."
          </blockquote>
          <p class="hero-signature">Fatmata</p>
          <div class="hero-ctas">
            <a href="/about" class="btn btn-outline-light">Learn More About Fatmata</a>
            <a href={donateUrl} class="btn btn-accent">Donate Now</a>
          </div>
        </div>
      </div>
    </section>

    <!-- TAGLINE -->
    <section class="tagline-section">
      <div class="container text-center">
        <h2 class="tagline-text">Let's Move Montgomery County Forward Together.</h2>
      </div>
    </section>

    <!-- CAMPAIGN PHOTOS -->
    <section class="section section-alt photos-section">
      <div class="container">
        <div class="photos-grid">
          <div class="photo-slot">
            <img src="/images/fatmata-about.png" alt="Fatmata at a campaign event" loading="lazy" />
          </div>
          <div class="photo-slot">
            <img src="/images/hero-vote.jpg" alt="Campaign trail" loading="lazy" />
          </div>
          <div class="photo-slot">
            <img src="/images/CampaignHeadshot32426-1.png" alt="Fatmata Barrie" loading="lazy" />
          </div>
          <div class="photo-slot photo-placeholder"><span>Campaign Photo</span></div>
          <div class="photo-slot photo-placeholder"><span>Campaign Photo</span></div>
          <div class="photo-slot photo-placeholder"><span>Campaign Photo</span></div>
          <div class="photo-slot photo-placeholder"><span>Campaign Photo</span></div>
          <div class="photo-slot photo-placeholder"><span>Campaign Photo</span></div>
          <div class="photo-slot photo-placeholder"><span>Campaign Photo</span></div>
        </div>
      </div>
    </section>

    <!-- SOCIAL FOLLOW -->
    <section class="section social-follow-section">
      <div class="container text-center">
        <p class="section-label">Stay Connected</p>
        <h3 class="social-heading">Follow Fatmata on Social Media</h3>
        <div class="social-icons-large">
          <a href={socialLinks.instagram} target="_blank" rel="noopener" aria-label="Instagram" class="social-icon-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
            <span>Instagram</span>
          </a>
          <a href={socialLinks.facebook} target="_blank" rel="noopener" aria-label="Facebook" class="social-icon-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="currentColor">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
            <span>Facebook</span>
          </a>
          <a href={socialLinks.bluesky} target="_blank" rel="noopener" aria-label="Bluesky" class="social-icon-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.767-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 0 1-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.479 0-.689-.139-1.861-.902-2.203-.659-.299-1.664-.621-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8Z"/>
            </svg>
            <span>Bluesky</span>
          </a>
        </div>
      </div>
    </section>

    <!-- MEET FATMATA -->
    <section class="section meet">
      <div class="container meet-inner">
        <div class="meet-portrait">
          <img src="/images/fatmata-about.png" alt="Fatmata Barrie" class="meet-portrait-img" />
        </div>
        <div class="meet-text">
          <p class="section-label">Meet Fatmata</p>
          <h2>Fatmata Barrie</h2>
          <span class="ornament" style="margin: 1rem 0;"></span>
          <p>Fatmata's story is representative of so many in Montgomery County. Originally from Sierra Leone, Fatmata emigrated to the US at age 11. She graduated from Florida A&amp;M University with a BS in Psychology before attaining her JD from the University of Florida Levin College of Law. She has been an immigration and special education attorney, community activist and organizer for more than 30 years, working with organizations including CASA de Maryland, ACLU of Montgomery County and Jews United for Justice.</p>
          <p>As a county resident for over 20 years, she previously served as the Executive Director of the Montgomery County Police Accountability Board and Administrative Charging Committee and she worked for Councilmember Will Jawando. A lifelong Democrat, Fatmata has been heavily involved in politics and engaging with diverse communities to get them involved in the political process.</p>
          <a href="/about" class="btn btn-outline">Learn More About Fatmata</a>
        </div>
      </div>
    </section>

    <SignupForm />

  </main>
  <Footer />
</BaseLayout>

<style>
  /* POPUP */
  .popup-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.65);
    z-index: 2000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .popup-overlay.active {
    opacity: 1;
    pointer-events: auto;
  }

  .popup-modal {
    background: var(--white);
    border-radius: 10px;
    padding: 2.5rem 2rem;
    max-width: 520px;
    width: 100%;
    position: relative;
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    text-align: center;
  }

  .popup-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 32px;
    height: 32px;
    font-size: 1.4rem;
    color: var(--text-light);
    cursor: pointer;
    border: none;
    background: none;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: background var(--transition);
  }

  .popup-close:hover { background: var(--cream-dark); }

  .popup-headline {
    font-family: var(--font-heading);
    font-size: clamp(1.2rem, 3vw, 1.6rem);
    color: var(--primary);
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .popup-text {
    font-size: 0.95rem;
    color: var(--text-light);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .donation-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.6rem;
  }

  .donation-btn {
    display: block;
    padding: 0.7rem 0.5rem;
    background: var(--primary);
    color: var(--white);
    font-family: var(--font-primary);
    font-weight: 700;
    font-size: 1rem;
    border-radius: 4px;
    text-align: center;
    transition: background var(--transition), transform var(--transition);
  }

  .donation-btn:hover {
    background: var(--accent);
    color: var(--white);
    transform: translateY(-2px);
  }

  .donation-other {
    grid-column: span 4;
    background: transparent;
    color: var(--primary);
    border: 2px solid var(--primary);
  }

  .donation-other:hover {
    background: var(--primary);
    color: var(--white);
  }

  @media (max-width: 480px) {
    .donation-grid { grid-template-columns: repeat(3, 1fr); }
    .donation-other { grid-column: span 3; }
  }

  /* HERO */
  .hero {
    position: relative;
    min-height: 85vh;
    display: flex;
    align-items: center;
    background: var(--primary);
    overflow: hidden;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: 3rem;
    align-items: center;
    padding: 4rem 1.5rem;
  }

  .hero-portrait {
    display: flex;
    justify-content: center;
    align-items: flex-end;
  }

  .hero-portrait-img {
    max-width: 100%;
    width: 420px;
    height: 520px;
    border-radius: 8px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.35);
    object-fit: cover;
    object-position: top;
  }

  .hero-quote {
    font-family: var(--font-heading);
    font-size: clamp(1.05rem, 2.2vw, 1.35rem);
    font-weight: 500;
    font-style: italic;
    line-height: 1.75;
    color: rgba(255,255,255,0.92);
    margin-bottom: 1.5rem;
    border-left: 4px solid var(--accent);
    padding-left: 1.25rem;
  }

  .hero-signature {
    font-family: 'Dancing Script', cursive;
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--white);
    margin-bottom: 2rem;
    line-height: 1;
  }

  .hero-ctas { display: flex; gap: 1rem; flex-wrap: wrap; }

  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; text-align: center; }
    .hero-portrait { order: -1; }
    .hero-portrait-img { width: 260px; height: 320px; }
    .hero-quote { border-left: none; padding-left: 0; text-align: left; }
    .hero-ctas { justify-content: center; }
    .hero-signature { text-align: center; }
  }

  /* TAGLINE */
  .tagline-section {
    background: var(--white);
    padding: 3.5rem 1.5rem;
    border-bottom: 3px solid var(--accent);
  }

  .tagline-text {
    font-family: var(--font-heading);
    font-size: clamp(1.6rem, 4vw, 2.75rem);
    font-weight: 700;
    color: var(--primary);
    line-height: 1.2;
    max-width: 800px;
    margin: 0 auto;
  }

  /* CAMPAIGN PHOTOS */
  .photos-section { background: var(--cream-dark); }

  .photos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }

  .photo-slot {
    aspect-ratio: 4/3;
    overflow: hidden;
    border-radius: var(--border-radius);
    background: var(--cream-dark);
  }

  .photo-slot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    transition: transform 0.4s ease;
  }

  .photo-slot:hover img { transform: scale(1.04); }

  .photo-placeholder {
    background: var(--mint);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px dashed var(--teal);
  }

  .photo-placeholder span {
    font-family: var(--font-primary);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--teal);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  @media (max-width: 640px) {
    .photos-grid { grid-template-columns: 1fr 1fr; }
  }

  /* SOCIAL FOLLOW */
  .social-follow-section { background: var(--white); }

  .social-heading {
    font-size: clamp(1.2rem, 2.5vw, 1.75rem);
    color: var(--text);
    margin-bottom: 2rem;
  }

  .social-icons-large {
    display: flex;
    justify-content: center;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .social-icon-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    color: #627af5;
    text-decoration: none;
    transition: transform var(--transition), color var(--transition);
  }

  .social-icon-link:hover {
    transform: translateY(-4px);
    color: var(--accent);
  }

  .social-icon-link span {
    font-family: var(--font-primary);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* MEET */
  .meet-inner {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 4rem;
    align-items: center;
  }

  .meet-portrait-img {
    width: 100%;
    max-width: 340px;
    height: auto;
    border-radius: 8px;
    border: 3px solid var(--teal);
    box-shadow: var(--shadow-md);
    object-fit: cover;
    margin: 0 auto;
    display: block;
  }

  .meet-text h2 { margin-bottom: 0; }
  .meet-text p { color: var(--text-light); font-size: 1.05rem; line-height: 1.7; margin-bottom: 1rem; }

  @media (max-width: 768px) {
    .meet-inner { grid-template-columns: 1fr; gap: 2rem; }
    .meet-portrait { order: -1; }
  }
</style>

<script>
  // Popup: show after 2s, once per session
  const popup = document.getElementById('donation-popup');
  const closeBtn = document.getElementById('popup-close-btn');

  function showPopup() {
    if (!sessionStorage.getItem('popupDismissed') && popup) {
      popup.classList.add('active');
      popup.setAttribute('aria-hidden', 'false');
    }
  }

  function dismissPopup() {
    popup?.classList.remove('active');
    popup?.setAttribute('aria-hidden', 'true');
    sessionStorage.setItem('popupDismissed', '1');
  }

  setTimeout(showPopup, 2000);

  closeBtn?.addEventListener('click', dismissPopup);

  popup?.addEventListener('click', (e) => {
    if (e.target === popup) dismissPopup();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') dismissPopup();
  });
</script>
