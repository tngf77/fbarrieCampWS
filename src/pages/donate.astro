---
import PageLayout from '../layouts/PageLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import { donateUrl } from '../data/navigation';
---

<PageLayout title="Donate | Fatmata Barrie for Montgomery County Council" description="Support Fatmata Barrie's people-powered campaign. Your donation is matched through Montgomery County's public financing program.">

  <HeroSection title="Donate" subtitle="Make an impact today! Donate to our campaign!" />

  <!-- MATCH EXPLAINER -->
  <section class="section">
    <div class="container">
      <div class="donate-top">
        <div class="donate-info">
          <p class="section-label">People-Powered Campaign</p>
          <h2>Make an impact today!</h2>
          <span class="ornament" style="margin: 0.75rem 0 1.25rem;"></span>
          <p>Fatmata is participating in the county's public financing fund! That means that this campaign is completely funded by you, the people.</p>
          <p>What this means is that your individual donations are matched and allows for your contribution to make a greater financial impact.</p>
        </div>
        <div class="donate-cta-card">
          <h3>Ready to contribute?</h3>
          <p>Every dollar you give is matched and goes directly to building a people-first campaign.</p>
          <div class="donate-amounts">
            {[5, 25, 50, 100, 150, 250, 500].map(amt => (
              <a href={`${donateUrl}?amount=${amt}`} class="donate-amount-btn" target="_blank" rel="noopener noreferrer">${amt}</a>
            ))}
          </div>
          <a href={donateUrl} target="_blank" rel="noopener noreferrer" class="btn btn-accent" style="width: 100%; margin-top: 1rem;">Other Amount</a>
          <p class="donate-fine">Maximum: $500 per cycle. Montgomery County residents only for matching.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- MATCH CHART -->
  <section class="section section-alt">
    <div class="container text-center">
      <p class="section-label">Matching Chart</p>
      <h2>See how far your donation goes.</h2>
      <span class="ornament"></span>
      <div class="match-table-wrap">
        <table class="match-table">
          <thead>
            <tr>
              <th>You Give</th>
              <th>County Match</th>
              <th>Total Impact</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>$25</td>
              <td>$125</td>
              <td class="match-total">$150</td>
            </tr>
            <tr>
              <td>$50</td>
              <td>$250</td>
              <td class="match-total">$300</td>
            </tr>
            <tr>
              <td>$150</td>
              <td>$500</td>
              <td class="match-total">$650</td>
            </tr>
            <tr class="match-highlight">
              <td>$250</td>
              <td>$500</td>
              <td class="match-total">$750</td>
            </tr>
            <tr>
              <td>$500</td>
              <td>$500</td>
              <td class="match-total">$1,000</td>
            </tr>
          </tbody>
        </table>
      </div>
      <a href={donateUrl} target="_blank" rel="noopener noreferrer" class="btn btn-accent" style="margin-top: 2rem;">Donate Now</a>
    </div>
  </section>

  <!-- RULES -->
  <section class="section">
    <div class="container">
      <div class="rules-grid">
        <div class="rule-card">
          <h3>Who can donate?</h3>
          <ul>
            <li>You MUST be a Permanent Resident or Citizen to donate to a political campaign</li>
            <li>Only contributions from Montgomery County residents will be matched from the Fund</li>
            <li>Individuals only &mdash; Fatmata doesn't take money from PACs, corporations, or political parties</li>
          </ul>
        </div>
        <div class="rule-card">
          <h3>Contribution limits</h3>
          <ul>
            <li>Individuals can only donate a maximum of $500 during the four-year cycle 1/1/2023 through 12/31/2026</li>
            <li>Donations are not tax-deductible</li>
          </ul>
        </div>
        <div class="rule-card">
          <h3>Why public financing?</h3>
          <ul>
            <li>This campaign is completely funded by you, the people</li>
            <li>Amplifies the voices of everyday Montgomery County residents</li>
            <li>Ensures this campaign serves the people &mdash; not corporations or PACs</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- GIVE BY CHECK -->
  <section class="section" id="give-by-check">
    <div class="container">
      <div class="check-grid">
        <div class="check-info">
          <p class="section-label">Prefer to Give by Check?</p>
          <h2>Mail your contribution</h2>
          <span class="ornament" style="margin: 0.75rem 0 1.25rem;"></span>
          <p>You can mail your contribution to:</p>
          <div class="mailing-address">
            <strong>Fatmata Barrie for Montgomery County</strong><br />
            PO Box 4496<br />
            Silver Spring, MD 20914
          </div>
          <p style="margin-top:1.25rem;">Please make checks payable to <strong>Fatmata Barrie for Montgomery County</strong>. Fill out the form to let us know your check is on the way — this helps us log your contribution accurately for public financing compliance.</p>
          <p><em>Reminder: Maximum $500 per cycle. You must be a U.S. citizen or permanent resident alien. Contributions are not tax-deductible.</em></p>
        </div>

        <div class="check-form-wrap">
          <h3>Let us know your check is coming</h3>
          <form
            name="check-donation"
            method="POST"
            data-netlify="true"
            data-netlify-honeypot="bot-field"
            class="check-form"
            id="check-donation-form"
          >
            <input type="hidden" name="form-name" value="check-donation" />
            <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>

            <div class="form-row">
              <div class="form-group">
                <label for="check-first-name">First Name *</label>
                <input type="text" id="check-first-name" name="first_name" required />
              </div>
              <div class="form-group">
                <label for="check-last-name">Last Name *</label>
                <input type="text" id="check-last-name" name="last_name" required />
              </div>
            </div>

            <div class="form-group">
              <label for="check-address">Home Street Address *</label>
              <input type="text" id="check-address" name="address" required placeholder="Required for public financing compliance" />
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="check-city">City *</label>
                <input type="text" id="check-city" name="city" required />
              </div>
              <div class="form-group form-group-sm">
                <label for="check-state">State *</label>
                <input type="text" id="check-state" name="state" required value="MD" maxlength="2" />
              </div>
              <div class="form-group form-group-sm">
                <label for="check-zip">ZIP *</label>
                <input type="text" id="check-zip" name="zip" required maxlength="10" />
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="check-email">Email Address</label>
                <input type="email" id="check-email" name="email" placeholder="So we can confirm receipt" />
              </div>
              <div class="form-group">
                <label for="check-phone">Phone Number</label>
                <input type="tel" id="check-phone" name="phone" placeholder="e.g. 301-555-1234" />
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="check-occupation">Occupation *</label>
                <input type="text" id="check-occupation" name="occupation" required placeholder="e.g. Teacher, Retired, Student" />
              </div>
              <div class="form-group">
                <label for="check-employer">Employer *</label>
                <input type="text" id="check-employer" name="employer" required placeholder="e.g. MCPS, Self-employed, N/A" />
              </div>
            </div>

            <div class="form-group">
              <label for="check-amount">Check Amount *</label>
              <div class="amount-input-wrap">
                <span class="amount-dollar">$</span>
                <input type="number" id="check-amount" name="amount" required min="1" max="500" placeholder="e.g. 25" />
              </div>
            </div>

            <div class="form-group form-checkbox">
              <label>
                <input type="checkbox" name="moco_resident" value="yes" />
                I am a Montgomery County resident (required for donation matching).
              </label>
            </div>

            <div class="public-financing-box">
              <p class="pf-title">Public Financing Information</p>
              <p class="pf-intro">By typing your name below as your digital signature, you affirm that you understand and agree to these Contribution Rules:</p>
              <ul class="pf-rules">
                <li>I am at least eighteen years old.</li>
                <li>This contribution is made in my name from my own funds and is not being reimbursed in any manner.</li>
                <li>This contribution is not made from the funds of a corporation or labor organization.</li>
                <li>This contribution is made on a personal credit card or debit card for which I have the legal obligation to pay and is not made either on a corporate or business entity card or on the card of another person.</li>
                <li>I certify that the information provided is accurate and truthful.</li>
                <li>I certify that I have not made individual aggregate contributions to Fatmata Barrie for Montgomery County of more than $500 for the election cycle.</li>
              </ul>
            </div>

            <div class="form-group">
              <label for="check-signature">Digital Signature *</label>
              <input type="text" id="check-signature" name="signature" required placeholder="Type your full legal name (no initials)" />
              <span class="field-note">Name must match your full contributor name — no initials please.</span>
            </div>

            <div id="check-form-status" class="form-status" aria-live="polite"></div>

            <button type="submit" class="btn btn-primary" style="width:100%; margin-top:0.5rem;">Submit Check Notification</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section donate-bottom-cta">
    <div class="container text-center">
      <h2 style="color: var(--white);">Every dollar counts.</h2>
      <span class="ornament" style="background: var(--gold);"></span>
      <p style="color: rgba(255,255,255,0.7); max-width: 600px; margin: 1rem auto 1.5rem; font-size: 1.1rem;">Even a $25 donation becomes $150 through matching. That's the power of people-powered politics.</p>
      <div class="donate-amounts donate-amounts-light">
        {[5, 25, 50, 100, 150, 250, 500].map(amt => (
          <a href={`${donateUrl}?amount=${amt}`} class="donate-amount-btn donate-amount-btn-light" target="_blank" rel="noopener noreferrer">${amt}</a>
        ))}
      </div>
      <a href={donateUrl} target="_blank" rel="noopener noreferrer" class="btn btn-accent btn-lg" style="margin-top: 1.5rem;">Other Amount</a>
    </div>
  </section>

<script>
  const form = document.getElementById('check-donation-form') as HTMLFormElement;
  const status = document.getElementById('check-form-status') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Submitting…';
    status.className = 'form-status';

    const data = new URLSearchParams(new FormData(form) as any);
    try {
      const res = await fetch('/', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: data.toString() });
      if (res.status >= 500) throw new Error();
      status.className = 'form-status success';
      status.textContent = 'Thank you! We\'ve received your notification and will look out for your check.';
      form.reset();
    } catch {
      status.className = 'form-status error';
      status.textContent = 'Something went wrong. Please try again or email info@fatmatabarrie.com.';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Submit Check Notification';
    }
  });
</script>

</PageLayout>

<style>
  .donate-top {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .donate-info h2 { margin-bottom: 0; }
  .donate-info p { color: var(--text-light); font-size: 1.05rem; line-height: 1.7; }

  .donate-cta-card {
    background: var(--white);
    border: 2px solid var(--primary);
    border-radius: var(--border-radius);
    padding: 2rem;
    box-shadow: var(--shadow-md);
  }

  .donate-cta-card h3 { font-size: 1.3rem; margin-bottom: 0.75rem; color: var(--primary); }
  .donate-cta-card p { color: var(--text-light); font-size: 0.95rem; line-height: 1.6; }
  .donate-fine { font-size: 0.75rem !important; opacity: 0.6; margin-top: 0.75rem; }

  /* TABLE */
  .match-table-wrap {
    max-width: 600px;
    margin: 1.5rem auto 0;
    overflow-x: auto;
  }

  .match-table {
    width: 100%;
    border-collapse: collapse;
    text-align: center;
  }

  .match-table th {
    font-family: var(--font-primary);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--teal);
    padding: 1rem;
    border-bottom: 2px solid var(--teal);
  }

  .match-table td {
    padding: 0.85rem 1rem;
    font-size: 1.1rem;
    color: var(--text);
    border-bottom: 1px solid var(--light-gray);
  }

  .match-total {
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--teal);
    font-size: 1.25rem;
  }

  .match-highlight { background: rgba(9,113,109,0.08); }

  /* RULES */
  .rules-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .rule-card {
    background: var(--white);
    border: 1px solid var(--light-gray);
    border-radius: var(--border-radius);
    padding: 1.75rem;
    box-shadow: var(--shadow-sm);
  }

  .rule-card h3 { font-size: 1.1rem; margin-bottom: 0.75rem; color: var(--teal); }
  .rule-card ul { list-style: disc; padding-left: 1.25rem; }
  .rule-card li { color: var(--text-light); font-size: 0.95rem; line-height: 1.6; margin-bottom: 0.5rem; }

  .donate-bottom-cta {
    background: var(--primary);
  }

  .btn-lg { padding: 1rem 3rem; font-size: 1.1rem; }

  .donate-amounts {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 1.25rem;
  }

  .donate-amount-btn {
    display: inline-block;
    padding: 0.55rem 1rem;
    border: 2px solid var(--gold);
    border-radius: 4px;
    font-family: var(--font-primary);
    font-weight: 700;
    font-size: 1rem;
    color: var(--gold);
    background: transparent;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
    min-width: 3.5rem;
    text-align: center;
  }

  .donate-amount-btn:hover {
    background: var(--gold);
    color: #fff;
  }

  .donate-amount-btn-light {
    border-color: rgba(255,255,255,0.7);
    color: #fff;
  }

  .donate-amount-btn-light:hover {
    background: rgba(255,255,255,0.2);
    color: #fff;
  }

  /* CHECK SECTION */
  .check-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 3rem;
    align-items: start;
  }

  .check-info p { color: var(--text-light); font-size: 1rem; line-height: 1.7; }
  .check-info h2 { margin-bottom: 0; }

  .mailing-address {
    background: var(--light-gray);
    border-left: 4px solid var(--teal);
    border-radius: 4px;
    padding: 1rem 1.25rem;
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text);
    margin-top: 0.5rem;
  }

  .check-form-wrap {
    background: var(--white);
    border: 2px solid var(--primary);
    border-radius: var(--border-radius);
    padding: 2rem;
    box-shadow: var(--shadow-md);
  }

  .check-form-wrap h3 { font-size: 1.2rem; color: var(--primary); margin-bottom: 1.25rem; }

  .check-form .form-row {
    display: flex;
    gap: 0.75rem;
  }

  .check-form .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    flex: 1;
    margin-bottom: 1rem;
  }

  .check-form .form-group-sm { flex: 0 0 5rem; }

  .check-form label {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text);
  }

  .check-form input[type="text"],
  .check-form input[type="email"],
  .check-form input[type="tel"],
  .check-form input[type="number"] {
    padding: 0.6rem 0.8rem;
    border: 1px solid #ccc;
    border-radius: 4px;
    font-size: 0.95rem;
    font-family: var(--font-body);
    color: var(--text);
    width: 100%;
    box-sizing: border-box;
  }

  .check-form input:focus {
    outline: 2px solid var(--primary);
    border-color: var(--primary);
  }

  .amount-input-wrap {
    display: flex;
    align-items: center;
    border: 1px solid #ccc;
    border-radius: 4px;
    overflow: hidden;
  }

  .amount-dollar {
    padding: 0.6rem 0.75rem;
    background: var(--light-gray);
    font-weight: 700;
    color: var(--text-light);
    border-right: 1px solid #ccc;
  }

  .amount-input-wrap input {
    border: none !important;
    border-radius: 0 !important;
  }

  .form-checkbox label {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.88rem;
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
    line-height: 1.5;
    cursor: pointer;
  }

  .form-checkbox input[type="checkbox"] {
    margin-top: 0.15rem;
    flex-shrink: 0;
    width: 1rem;
    height: 1rem;
    accent-color: var(--primary);
  }

  .form-status {
    padding: 0.75rem 1rem;
    border-radius: 4px;
    font-size: 0.9rem;
    display: none;
    margin-bottom: 0.75rem;
  }

  .form-status.success { display: block; background: #e6f4ea; color: #1a6b2a; border: 1px solid #a8d5b0; }
  .form-status.error { display: block; background: #fdecea; color: #9b2c2c; border: 1px solid #f5c6c6; }

  .hidden { display: none; }

  .public-financing-box {
    background: #f5f7fa;
    border: 1px solid #c8d0dc;
    border-left: 4px solid var(--primary);
    border-radius: 4px;
    padding: 1.1rem 1.25rem;
    margin-bottom: 1rem;
  }

  .pf-title {
    font-family: var(--font-primary);
    font-weight: 700;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--primary);
    margin: 0 0 0.4rem !important;
  }

  .pf-intro {
    font-size: 0.88rem;
    color: var(--text-light);
    margin: 0 0 0.6rem !important;
    line-height: 1.5;
  }

  .pf-rules {
    list-style: disc;
    padding-left: 1.25rem;
    margin: 0;
  }

  .pf-rules li {
    font-size: 0.85rem;
    color: var(--text-light);
    line-height: 1.55;
    margin-bottom: 0.35rem;
  }

  .field-note {
    font-size: 0.78rem;
    color: var(--text-light);
    margin-top: 0.25rem;
    font-style: italic;
  }

  @media (max-width: 768px) {
    .donate-top { grid-template-columns: 1fr; gap: 2rem; }
    .rules-grid { grid-template-columns: 1fr; }
    .check-grid { grid-template-columns: 1fr; gap: 2rem; }
    .check-form .form-row { flex-direction: column; gap: 0; }
    .check-form .form-group-sm { flex: 1; }
  }
</style>
