---
import PageLayout from '../layouts/PageLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import SignupForm from '../components/SignupForm.astro';
import { donateUrl } from '../data/navigation';

const events = [
  {
    id: 'fundraiser-apr-2026',
    type: 'Fundraiser',
    title: 'Fundraiser for Fatmata Barrie',
    date: '2026-04-11',
    timeStart: '4:00 PM',
    timeEnd: '6:00 PM',
    location: 'Germantown, MD',
    locationNote: 'Address provided upon registration',
    description: 'Join us for a fundraiser in support of Fatmata Barrie\'s campaign for Montgomery County Council At-Large. Come meet Fatmata, connect with neighbors, and help power a campaign that\'s funded entirely by people — not corporations or PACs.',
    hosts: ['Comfort Yirenkyi', 'Amy Bisle', 'Mumin Barre', 'Guy Djoken', 'Torian Richardson'],
    rsvpUrl: 'https://donorbox.org/events/917580',
    contactEmail: 'events@fatmatabarrie.com',
    graphic: '/images/Dono Fundraiser Graphic.png',
  },
];

function formatDate(dateStr: string) {
  const d = new Date(dateStr + 'T00:00:00');
  return d.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
}
---

<PageLayout title="Events | Fatmata Barrie for Montgomery County Council" description="Upcoming campaign events for Fatmata Barrie for Montgomery County Council At-Large. Join us in Germantown and across MoCo.">

  <HeroSection title="Events" subtitle="Come meet Fatmata and get involved in person." />

  <section class="section">
    <div class="container">

      {events.length === 0 ? (
        <div class="no-events text-center">
          <p class="section-label">Coming Soon</p>
          <h2>No upcoming events right now.</h2>
          <span class="ornament"></span>
          <p style="color: var(--text-light); margin: 1rem auto 2rem; max-width: 480px;">Check back soon — events will be posted here as they're scheduled. Sign up below to be the first to know.</p>
        </div>
      ) : (
        <div class="events-list">
          {events.map(event => (
            <div class="event-card" id={event.id}>

              <div class="event-main">
                <div class="event-info">
                  <span class={`event-badge badge-${event.type.toLowerCase()}`}>{event.type}</span>
                  <h2 class="event-title">{event.title}</h2>

                  <div class="event-meta">
                    <div class="meta-row">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                      <span>{formatDate(event.date)}</span>
                    </div>
                    <div class="meta-row">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                      <span>{event.timeStart} – {event.timeEnd}</span>
                    </div>
                    <div class="meta-row">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                      <span>{event.location} <span class="location-note">— {event.locationNote}</span></span>
                    </div>
                    <div class="meta-row">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                      <a href={`mailto:${event.contactEmail}`}>{event.contactEmail}</a>
                    </div>
                  </div>

                  <p class="event-description">{event.description}</p>

                  {event.hosts && event.hosts.length > 0 && (
                    <div class="event-hosts">
                      <p class="hosts-label">Host Committee</p>
                      <ul>
                        {event.hosts.map(host => <li>{host}</li>)}
                      </ul>
                    </div>
                  )}

                  <div class="event-actions">
                    <a href={event.rsvpUrl} target="_blank" rel="noopener" class="btn btn-accent">RSVP / Donate Online</a>
                    <a href={donateUrl} class="btn btn-primary">Donate to the Campaign</a>
                  </div>
                </div>

                <div class="event-graphic-wrap">
                  <img src={event.graphic} alt={`Event graphic: ${event.title}`} class="event-graphic" />
                </div>
              </div>

            </div>
          ))}
        </div>
      )}

    </div>
  </section>

  <!-- CTA -->
  <section class="section section-alt">
    <div class="container text-center">
      <p class="section-label">Can't Make It?</p>
      <h2>There are other ways to help.</h2>
      <span class="ornament"></span>
      <p style="color: var(--text-light); font-size: 1.05rem; margin: 1rem auto 2rem; max-width: 500px;">Donate, volunteer, or spread the word — every action moves Montgomery County forward.</p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href={donateUrl} class="btn btn-accent">Donate Now</a>
        <a href="/volunteer" class="btn btn-primary">Get Involved</a>
      </div>
    </div>
  </section>

  <SignupForm />

</PageLayout>

<style>
  .events-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .event-card {
    background: var(--white);
    border: 1px solid var(--light-gray);
    border-radius: var(--border-radius);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    border-left: 4px solid var(--accent);
  }

  .event-main {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 0;
    align-items: start;
  }

  .event-info {
    padding: 2.5rem;
  }

  .event-badge {
    display: inline-block;
    font-family: var(--font-primary);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.25rem 0.85rem;
    border-radius: 3px;
    margin-bottom: 0.75rem;
  }

  .badge-fundraiser {
    background: rgba(228,83,67,0.12);
    color: var(--accent);
  }

  .badge-townhall, .badge-community {
    background: rgba(9,113,109,0.1);
    color: var(--teal);
  }

  .event-title {
    font-size: clamp(1.3rem, 2.5vw, 1.8rem);
    color: var(--primary);
    margin-bottom: 1.25rem;
    line-height: 1.25;
  }

  .event-meta {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--light-gray);
  }

  .meta-row {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    font-size: 0.95rem;
    color: var(--text);
  }

  .meta-row svg { flex-shrink: 0; color: var(--teal); }
  .meta-row a { color: var(--primary); font-weight: 600; }
  .meta-row a:hover { color: var(--teal); }
  .location-note { color: var(--text-light); font-size: 0.88rem; }

  .event-description {
    font-size: 1rem;
    color: var(--text-light);
    line-height: 1.75;
    margin-bottom: 1.5rem;
  }

  .event-hosts {
    background: var(--cream);
    border-radius: 6px;
    padding: 1rem 1.25rem;
    margin-bottom: 1.75rem;
  }

  .hosts-label {
    font-family: var(--font-primary);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--teal);
    margin-bottom: 0.5rem;
  }

  .event-hosts ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 1.25rem;
  }

  .event-hosts ul li {
    font-size: 0.9rem;
    color: var(--text);
    font-weight: 600;
    position: relative;
    padding-left: 0.85rem;
  }

  .event-hosts ul li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5rem;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
  }

  .event-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .event-graphic-wrap {
    border-left: 1px solid var(--light-gray);
    display: flex;
    align-items: flex-start;
    padding: 1.5rem;
    background: var(--cream);
  }

  .event-graphic {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 6px;
    box-shadow: var(--shadow-sm);
  }

  .no-events { padding: 3rem 0; }

  @media (max-width: 900px) {
    .event-main { grid-template-columns: 1fr; }
    .event-graphic-wrap { border-left: none; border-top: 1px solid var(--light-gray); max-height: 420px; }
    .event-graphic { object-position: top; }
  }

  @media (max-width: 600px) {
    .event-info { padding: 1.5rem; }
    .event-actions { flex-direction: column; }
    .event-actions .btn { text-align: center; }
  }
</style>
