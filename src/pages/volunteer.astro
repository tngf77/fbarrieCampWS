---
import PageLayout from '../layouts/PageLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import { donateUrl, socialLinks } from '../data/navigation';
---

<PageLayout title="Get Involved | Fatmata Barrie for Montgomery County Council" description="Join Team Barrie — volunteer, donate, and help move Montgomery County forward together.">

  <HeroSection title="Get Involved" subtitle="This campaign is powered by people like you." />

  <!-- WAYS TO HELP -->
  <section class="section">
    <div class="container">
      <div class="text-center" style="margin-bottom: 3rem;">
        <p class="section-label">Join the Movement</p>
        <h2>There are many ways to help.</h2>
        <span class="ornament"></span>
      </div>
      <div class="ways-grid">
        <div class="way-card">
          <h3>Volunteer Your Time</h3>
          <p>Canvass, phone bank, attend events, or help with operations. Every hour makes a difference in a people-powered campaign.</p>
        </div>
        <div class="way-card">
          <h3>Donate</h3>
          <p>Your small-dollar donation is matched through Montgomery County's public financing program. $25 becomes $150!</p>
          <a href={donateUrl} class="btn btn-accent" style="margin-top: 1rem;">Donate Now</a>
        </div>
        <div class="way-card">
          <h3>Spread the Word</h3>
          <p>Share Fatmata's story on social media, talk to neighbors, and help spread the message across Montgomery County.</p>
          <div class="way-social">
            <a href={socialLinks.facebook} target="_blank" rel="noopener">Facebook</a>
            <a href={socialLinks.instagram} target="_blank" rel="noopener">Instagram</a>
            <a href={socialLinks.twitter} target="_blank" rel="noopener">Twitter/X</a>
          </div>
        </div>
        <div class="way-card">
          <h3>Host an Event</h3>
          <p>Invite Fatmata to speak at your community event, house party, or neighborhood meeting.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- VOLUNTEER FORM -->
  <section class="section section-alt" id="form">
    <div class="container">
      <div class="vol-form-wrap">
        <div class="vol-form-info">
          <p class="section-label">Volunteer Sign-Up</p>
          <h2>Join Team Barrie.</h2>
          <span class="ornament" style="margin: 0.75rem 0 1.25rem;"></span>
          <p>Fill out the form and we'll reach out with volunteer opportunities that match your availability and interests.</p>
          <div class="vol-checks">
            <div class="vol-check"><span class="check-mark">&#x2713;</span><span>Canvassing & door knocking</span></div>
            <div class="vol-check"><span class="check-mark">&#x2713;</span><span>Phone banking</span></div>
            <div class="vol-check"><span class="check-mark">&#x2713;</span><span>Event support</span></div>
            <div class="vol-check"><span class="check-mark">&#x2713;</span><span>Social media outreach</span></div>
            <div class="vol-check"><span class="check-mark">&#x2713;</span><span>Yard sign placement</span></div>
          </div>
        </div>
        <div class="vol-form-card">
          <form class="vol-form" method="POST" action="#form">
            <div class="vf-row">
              <div class="vf-field">
                <label for="vf-fname">First Name</label>
                <input type="text" id="vf-fname" name="first_name" required />
              </div>
              <div class="vf-field">
                <label for="vf-lname">Last Name</label>
                <input type="text" id="vf-lname" name="last_name" required />
              </div>
            </div>
            <div class="vf-field">
              <label for="vf-email">Email Address</label>
              <input type="email" id="vf-email" name="email" required />
            </div>
            <div class="vf-row">
              <div class="vf-field">
                <label for="vf-phone">Phone</label>
                <input type="tel" id="vf-phone" name="phone" />
              </div>
              <div class="vf-field">
                <label for="vf-zip">Zip Code</label>
                <input type="text" id="vf-zip" name="zip" inputmode="numeric" pattern="[0-9]{5}" required />
              </div>
            </div>
            <div class="vf-field">
              <label for="vf-interest">How would you like to help?</label>
              <select id="vf-interest" name="interest">
                <option value="">Select an option</option>
                <option value="canvass">Canvassing & Door Knocking</option>
                <option value="phone">Phone Banking</option>
                <option value="events">Event Support</option>
                <option value="social">Social Media</option>
                <option value="signs">Yard Signs</option>
                <option value="other">Other</option>
              </select>
            </div>
            <button type="submit" class="btn btn-primary" style="width: 100%;">Sign Up to Volunteer</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container text-center">
      <h2>Can't volunteer? Donate instead.</h2>
      <span class="ornament"></span>
      <p style="color: var(--text-light); max-width: 550px; margin: 1rem auto 2rem;">Your donation is matched through Montgomery County's public financing program. No corporate money — just real people investing in our future.</p>
      <a href={donateUrl} class="btn btn-accent">Donate Now</a>
    </div>
  </section>

</PageLayout>

<style>
  .ways-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .way-card {
    background: var(--white);
    border: 1px solid var(--light-gray);
    border-radius: var(--border-radius);
    padding: 2rem;
    transition: border-color 0.3s, transform 0.2s;
    box-shadow: var(--shadow-sm);
  }

  .way-card:hover {
    border-color: var(--primary);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .way-card h3 { font-size: 1.2rem; margin-bottom: 0.75rem; color: var(--teal); }
  .way-card p { color: var(--text-light); font-size: 0.95rem; line-height: 1.6; }

  .way-social { display: flex; gap: 0.5rem; margin-top: 1rem; flex-wrap: wrap; }
  .way-social a {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.4rem 1rem;
    border: 1px solid var(--light-gray);
    border-radius: 4px;
    color: var(--primary);
    transition: all var(--transition);
  }
  .way-social a:hover { background: var(--primary); color: var(--white); border-color: var(--primary); }

  /* FORM */
  .vol-form-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .vol-form-info h2 { margin-bottom: 0; }
  .vol-form-info > p { color: var(--text-light); font-size: 1.05rem; line-height: 1.7; margin-bottom: 1.5rem; }

  .vol-checks { display: flex; flex-direction: column; gap: 0.6rem; }
  .vol-check { display: flex; align-items: center; gap: 0.75rem; color: var(--text); font-size: 0.95rem; }
  .check-mark { color: var(--teal); font-weight: 700; font-size: 1.1rem; }

  .vol-form-card {
    background: var(--white);
    border: 1px solid var(--light-gray);
    border-radius: var(--border-radius);
    padding: 2rem;
    box-shadow: var(--shadow-sm);
  }

  .vf-row { display: flex; gap: 0.75rem; }
  .vf-field { flex: 1; display: flex; flex-direction: column; margin-bottom: 0.75rem; }

  .vf-field label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--dark-gray);
    margin-bottom: 0.3rem;
  }

  .vf-field input,
  .vf-field select {
    padding: 0.7rem 0.65rem;
    font-size: 1rem;
    font-family: var(--font-primary);
    background: var(--cream);
    border: 2px solid var(--light-gray);
    border-radius: 4px;
    color: var(--text);
    outline: none;
    transition: border-color 0.2s;
  }

  .vf-field input:focus,
  .vf-field select:focus { border-color: var(--primary); }

  .vf-field select {
    appearance: none;
    background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%236B6358' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
    background-repeat: no-repeat;
    background-position: right 0.65rem center;
    background-size: 1rem;
    padding-right: 2.5rem;
  }

  @media (max-width: 768px) {
    .ways-grid { grid-template-columns: 1fr; }
    .vol-form-wrap { grid-template-columns: 1fr; gap: 2rem; }
    .vf-row { flex-direction: column; gap: 0; }
  }
</style>
