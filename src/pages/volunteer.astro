---
import PageLayout from '../layouts/PageLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import { donateUrl, socialLinks } from '../data/navigation';

const followLinks = [
  { label: 'Facebook', href: socialLinks.facebook, icon: '<path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>' },
  { label: 'Instagram', href: socialLinks.instagram, icon: '<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>' },
  { label: 'X / Twitter', href: socialLinks.twitter, icon: '<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>' },
  { label: 'Bluesky', href: socialLinks.bluesky, icon: '<path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 01-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.478 0-.69-.139-1.861-.902-2.204-.659-.299-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8z"/>' },
];
---

<PageLayout title="Get Involved | Fatmata Barrie for Montgomery County Council" description="Join Team Barrie — volunteer, donate, and help move Montgomery County forward together.">

  <HeroSection title="Get Involved" subtitle="Join me in shaping a future that works for everyone!" />

  <!-- WAYS TO HELP -->
  <section class="section">
    <div class="container">
      <div class="text-center" style="margin-bottom: 3rem;">
        <p class="section-label">Join the Movement</p>
        <h2>There are many ways to help.</h2>
        <span class="ornament"></span>
      </div>
      <div class="ways-grid">
        <div class="way-card">
          <h3>Volunteer Your Time</h3>
          <p>Canvass, phone bank, attend events, or help with operations. Let's move Montgomery County forward &mdash; together.</p>
          <a href="https://forms.gle/cw9hp3M5cv7HEfNd8" target="_blank" rel="noopener" class="btn btn-accent" style="margin-top: 1rem;">Sign Up</a>
        </div>
        <div class="way-card">
          <h3>Donate</h3>
          <p>Your small-dollar donation is matched through Montgomery County's public financing program. $25 becomes $150!</p>
          <a href={donateUrl} target="_blank" rel="noopener noreferrer" class="btn btn-accent" style="margin-top: 1rem;">Donate Now</a>
        </div>
        <div class="way-card">
          <h3>Spread the Word</h3>
          <p>Share Fatmata's story on social media, talk to neighbors, and help spread the message across Montgomery County.</p>
          <div class="way-social">
            <a href="https://www.facebook.com/sharer/sharer.php?u=https%3A%2F%2Ffatmatabarrie.com&quote=I%27m+supporting+Fatmata+Barrie+for+Montgomery+County+Council+At-Large+%E2%80%94+join+me!" target="_blank" rel="noopener">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              Share on Facebook
            </a>
            <a href="https://www.instagram.com/barrie4council/" target="_blank" rel="noopener">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              Share on Instagram
            </a>
            <a href="https://twitter.com/intent/tweet?text=I%27m+supporting+Fatmata+Barrie+for+Montgomery+County+Council+At-Large+%E2%80%94+join+me!&url=https%3A%2F%2Ffatmatabarrie.com" target="_blank" rel="noopener">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              Share on X
            </a>
            <a href="https://bsky.app/intent/compose?text=I%27m+supporting+Fatmata+Barrie+for+Montgomery+County+Council+At-Large+%E2%80%94+join+me!+https%3A%2F%2Ffatmatabarrie.com" target="_blank" rel="noopener">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 01-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.478 0-.69-.139-1.861-.902-2.204-.659-.299-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8z"/></svg>
              Share on Bluesky
            </a>
            <a href="https://www.linkedin.com/sharing/share-offsite/?url=https%3A%2F%2Ffatmatabarrie.com" target="_blank" rel="noopener">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              Share on LinkedIn
            </a>
          </div>
        </div>
        <div class="way-card">
          <h3>Host an Event</h3>
          <p>Invite Fatmata to speak at your community event, house party, or neighborhood meeting.</p>
          <a href="https://forms.gle/cw9hp3M5cv7HEfNd8" target="_blank" rel="noopener" class="btn btn-accent" style="margin-top: 1rem;">Request an Event</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FOLLOW US -->
  <section class="section section-alt follow-section">
    <div class="container text-center">
      <p class="section-label">Stay in the Loop</p>
      <h2>Follow Us on Social Media</h2>
      <span class="ornament"></span>
      <p class="follow-sub">Get the latest updates, events, and campaign news directly in your feed.</p>
      <div class="follow-grid">
        {followLinks.map(link => (
          <a href={link.href} target="_blank" rel="noopener" class="follow-card">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" set:html={link.icon} />
            <span>{link.label}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- VOTER REGISTRATION -->
  <section class="section">
    <div class="container">
      <div class="voter-reg-box">
        <div class="voter-reg-text">
          <p class="section-label">Make Your Voice Heard in the Primary</p>
          <h2>Is your voter registration up to date?</h2>
          <span class="ornament" style="margin: 0.75rem 0 1.25rem;"></span>
          <p>Maryland has closed primary elections, meaning you must be registered with a political party to vote in that party's primary.</p>
          <p>In Montgomery County, many local races are decided in the Democratic primary. To vote for Fatmata for County Council At-Large, you must be a registered Democrat by the registration deadline.</p>
          <p>Be sure to check your voter registration status and make any updates in time to participate.</p>
          <a href="https://voterservices.elections.maryland.gov/VoterSearch" target="_blank" rel="noopener" class="btn btn-primary" style="margin-top: 1rem;">Check Your Voter Registration</a>
        </div>
      </div>
    </div>
  </section>

  <!-- VOLUNTEER FORM -->
  <section class="section section-alt" id="form">
    <div class="container">
      <div class="vol-form-wrap">
        <div class="vol-left">
          <div class="vol-form-info">
            <p class="section-label">Volunteer Sign-Up</p>
            <h2>Join Team Barrie.</h2>
            <span class="ornament" style="margin: 0.75rem 0 1.25rem;"></span>
            <p>Fill out the form and we'll reach out with volunteer opportunities that match your availability and interests.</p>
            <div class="vol-checks">
              <div class="vol-check"><span class="check-mark">&#x2713;</span><span>Canvassing & door knocking</span></div>
              <div class="vol-check"><span class="check-mark">&#x2713;</span><span>Phone banking</span></div>
              <div class="vol-check"><span class="check-mark">&#x2713;</span><span>Event support</span></div>
              <div class="vol-check"><span class="check-mark">&#x2713;</span><span>Social media outreach</span></div>
              <div class="vol-check"><span class="check-mark">&#x2713;</span><span>Yard sign placement</span></div>
            </div>
          </div>
          <div class="vol-form-card">
            <form class="vol-form" method="POST" action="#form">
              <div class="vf-row">
                <div class="vf-field">
                  <label for="vf-fname">First Name</label>
                  <input type="text" id="vf-fname" name="first_name" required />
                </div>
                <div class="vf-field">
                  <label for="vf-lname">Last Name</label>
                  <input type="text" id="vf-lname" name="last_name" required />
                </div>
              </div>
              <div class="vf-field">
                <label for="vf-email">Email Address</label>
                <input type="email" id="vf-email" name="email" required />
              </div>
              <div class="vf-row">
                <div class="vf-field">
                  <label for="vf-phone">Phone</label>
                  <input type="tel" id="vf-phone" name="phone" />
                </div>
                <div class="vf-field">
                  <label for="vf-zip">Zip Code</label>
                  <input type="text" id="vf-zip" name="zip" inputmode="numeric" pattern="[0-9]{5}" required />
                </div>
              </div>
              <div class="vf-field">
                <label for="vf-interest">How would you like to help?</label>
                <select id="vf-interest" name="interest">
                  <option value="">Select an option</option>
                  <option value="canvass">Canvassing & Door Knocking</option>
                  <option value="phone">Phone Banking</option>
                  <option value="events">Event Support</option>
                  <option value="social">Social Media</option>
                  <option value="signs">Yard Signs</option>
                  <option value="other">Other</option>
                </select>
              </div>
              <button type="submit" class="btn btn-primary" style="width: 100%;">Sign Up to Volunteer</button>
            </form>
          </div>
        </div>
        <div class="vol-kickoff-img">
          <img src="/images/Campaign Kickoff 033026.jpg" alt="Campaign Kickoff" class="kickoff-img" />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container text-center">
      <h2>Can't volunteer? Donate instead.</h2>
      <span class="ornament"></span>
      <p style="color: var(--text-light); max-width: 550px; margin: 1rem auto 2rem;">Fatmata is participating in the county's public financing fund! That means this campaign is completely funded by you, the people. Your donation is matched &mdash; $25 becomes $150.</p>
      <a href={donateUrl} target="_blank" rel="noopener noreferrer" class="btn btn-accent">Donate Now</a>
    </div>
  </section>

</PageLayout>

<style>
  .ways-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .way-card {
    background: var(--white);
    border: 1px solid var(--light-gray);
    border-radius: var(--border-radius);
    padding: 2rem;
    transition: border-color 0.3s, transform 0.2s;
    box-shadow: var(--shadow-sm);
  }

  .way-card:hover {
    border-color: var(--primary);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .way-card h3 { font-size: 1.2rem; margin-bottom: 0.75rem; color: var(--teal); }
  .way-card p { color: var(--text-light); font-size: 0.95rem; line-height: 1.6; }

  .way-social { display: flex; gap: 0.5rem; margin-top: 1rem; flex-wrap: wrap; }
  .way-social a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.45rem 0.9rem;
    border: 1px solid var(--light-gray);
    border-radius: 4px;
    color: var(--primary);
    transition: all var(--transition);
  }
  .way-social a:hover { background: var(--primary); color: var(--white); border-color: var(--primary); }

  /* FOLLOW US */
  .follow-sub {
    color: var(--text-light);
    font-size: 1rem;
    margin: 0.75rem auto 2rem;
    max-width: 480px;
  }

  .follow-grid {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .follow-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1.5rem 2rem;
    background: var(--white);
    border: 2px solid var(--light-gray);
    border-radius: var(--border-radius);
    color: var(--primary);
    min-width: 110px;
    transition: all var(--transition);
    box-shadow: var(--shadow-sm);
  }

  .follow-card:hover {
    border-color: var(--teal);
    color: var(--teal);
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }

  .follow-card span {
    font-family: var(--font-primary);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* VOTER REGISTRATION */
  .voter-reg-box {
    background: var(--white);
    border: 2px solid var(--primary);
    border-radius: var(--border-radius);
    padding: 2.5rem 3rem;
    box-shadow: var(--shadow-sm);
    max-width: 750px;
    margin: 0 auto;
  }

  .voter-reg-text h2 { margin-bottom: 0; }

  .voter-reg-text p {
    color: var(--text-light);
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }

  /* FORM */
  .vol-form-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  .vol-left {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .vol-kickoff-img { align-self: start; }

  .kickoff-img {
    width: 100%;
    height: auto;
    border-radius: var(--border-radius);
    box-shadow: var(--shadow-md);
    display: block;
  }

  .vol-form-info h2 { margin-bottom: 0; }
  .vol-form-info > p { color: var(--text-light); font-size: 1.05rem; line-height: 1.7; margin-bottom: 1.5rem; }

  .vol-checks { display: flex; flex-direction: column; gap: 0.6rem; }
  .vol-check { display: flex; align-items: center; gap: 0.75rem; color: var(--text); font-size: 0.95rem; }
  .check-mark { color: var(--teal); font-weight: 700; font-size: 1.1rem; }

  .vol-form-card {
    background: var(--white);
    border: 1px solid var(--light-gray);
    border-radius: var(--border-radius);
    padding: 2rem;
    box-shadow: var(--shadow-sm);
  }

  .vf-row { display: flex; gap: 0.75rem; }
  .vf-field { flex: 1; display: flex; flex-direction: column; margin-bottom: 0.75rem; }

  .vf-field label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--dark-gray);
    margin-bottom: 0.3rem;
  }

  .vf-field input,
  .vf-field select {
    padding: 0.7rem 0.65rem;
    font-size: 1rem;
    font-family: var(--font-primary);
    background: var(--cream);
    border: 2px solid var(--light-gray);
    border-radius: 4px;
    color: var(--text);
    outline: none;
    transition: border-color 0.2s;
  }

  .vf-field input:focus,
  .vf-field select:focus { border-color: var(--primary); }

  .vf-field select {
    appearance: none;
    background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%236B6358' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
    background-repeat: no-repeat;
    background-position: right 0.65rem center;
    background-size: 1rem;
    padding-right: 2.5rem;
  }

  @media (max-width: 900px) {
    .vol-form-wrap { grid-template-columns: 1fr; gap: 2rem; }
  }

  @media (max-width: 768px) {
    .ways-grid { grid-template-columns: 1fr; }
    .vf-row { flex-direction: column; gap: 0; }
  }
</style>
